# ================================================
# Synthetic Data Generation Platform - Environment
# ================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ================================================

# --- Application ---
APP_NAME=Synthetic Data Generator
APP_ENV=production
DEBUG=false

# --- Secrets (REQUIRED – generate with: python -c "import secrets; print(secrets.token_urlsafe(48))") ---
SECRET_KEY=
JWT_SECRET_KEY=
API_KEY=

# --- API Settings ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=synthetic_data
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/synthetic_data
DATABASE_ECHO=false

# --- Redis ---
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000

# --- File Storage ---
STORAGE_PATH=./generated_data
MAX_FILE_AGE_DAYS=7
MAX_UPLOAD_SIZE_MB=50
MODEL_STORAGE_PATH=./fitted_models

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# --- Password Policy ---
MIN_PASSWORD_LENGTH=8
REQUIRE_PASSWORD_UPPERCASE=true
REQUIRE_PASSWORD_DIGIT=true

# --- Generation Limits ---
MIN_RECORDS=100
MAX_RECORDS=1000000
DEFAULT_RECORDS=1000

# --- Flower (Celery monitoring) ---
FLOWER_USER=admin
FLOWER_PASSWORD=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- AI / Gemini ---
GEMINI_API_KEY=AIzaSyBGAHfgZlsn5LTXuzl3Hjjwkx26knT23O8
